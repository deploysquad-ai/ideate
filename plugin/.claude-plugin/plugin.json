{
  "name": "ideate",
  "description": "Turn conversations into structured project briefs using git-like branching, artifact extraction, and document generation.",
  "version": "0.2.0",
  "author": {
    "name": "DeploySquad",
    "email": "hi@deploysquad.ai",
    "url": "https://github.com/deploysquad-ai/ideate"
  },
  "homepage": "https://github.com/deploysquad-ai/ideate",
  "repository": "https://github.com/deploysquad-ai/ideate",
  "license": "MIT",
  "keywords": [
    "ideation",
    "brainstorming",
    "product-design",
    "document-generation",
    "branching",
    "context-isolation"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-resume.sh"
          }
        ]
      }
    ]
  }
}
